rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Role is stored in Firestore users/{uid}.role (not as a custom auth claim).
    function isStaff() {
      return request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'teacher'];
    }

    match /gallery/{imageId} {
      allow read: if request.auth != null;
      allow write: if isStaff()
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /feed_posts/{postId}/{imageId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /students/{studentId}/profile.{ext} {
      allow read: if request.auth != null;
      allow write: if isStaff()
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
