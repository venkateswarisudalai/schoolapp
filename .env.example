# Firebase Configuration for school-c0203
# Copy this file to .env and fill in your values from Firebase Console
# Go to: Project Settings > General > Your apps > Web app config

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=school-c0203.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=school-c0203
VITE_FIREBASE_STORAGE_BUCKET=school-c0203.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# EmailJS — delivers app feedback to the owner's inbox (venkateswari1095@gmail.com).
# Sign up free at https://www.emailjs.com, add an email service + a template, then:
#   Account > General  -> Public Key
#   Email Services     -> Service ID
#   Email Templates    -> Template ID
# Template variables to include: to_email, category, rating, message, from_name, from_email, user_role, app_version
# If these are left blank, feedback still saves to Firestore (no email sent).
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key_here
