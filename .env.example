# Firebase Configuration for school-c0203
# Copy this file to .env and fill in your values from Firebase Console
# Go to: Project Settings > General > Your apps > Web app config

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=school-c0203.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=school-c0203
VITE_FIREBASE_STORAGE_BUCKET=school-c0203.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here
