rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approvalStatus == 'approved';
    }

    // Helper function to check if user is teacher
    function isTeacher() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approvalStatus == 'approved';
    }

    // Helper function to check if user is approved
    function isApproved() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approvalStatus == 'approved';
    }

    // Users collection
    match /users/{userId} {
      // Only authenticated users can read profiles
      allow read: if request.auth != null;

      // Anyone authenticated can create their own profile OR any other user's profile
      // This allows newly created users (by admin) to have their profile created
      allow create: if request.auth != null;

      // Users can update their own profile, admins can update any
      allow update: if request.auth != null &&
        (request.auth.uid == userId || isAdmin());

      // Only admins can delete
      allow delete: if isAdmin();
    }

    // Attendance collection
    // Approved parents can create/update via QR check-in; teachers/admins can do all
    match /attendance/{attendanceId} {
      allow read: if isApproved();
      allow create: if isApproved();
      allow update: if isApproved();
      allow delete: if isAdmin();
    }

    // Fee config collection (admin sets fees)
    match /fee_config/{configId} {
      allow read: if isApproved();
      allow create, update, delete: if isAdmin();
    }

    // Fee payments collection
    match /fee_payments/{paymentId} {
      allow read: if isApproved();
      allow create, update: if isApproved();
      allow delete: if isAdmin();
    }

    // Children collection
    match /children/{childId} {
      allow read: if isApproved();
      // Allow authenticated users to create (for admin-created students where session switches)
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // Classes collection
    match /classes/{classId} {
      allow read: if isApproved();
      allow create, update, delete: if isAdmin();
    }

    // Announcements collection
    match /announcements/{announcementId} {
      allow read: if request.auth != null;
      allow create: if isTeacher() || isAdmin();
      allow update, delete: if isAdmin() || isTeacher();
    }

    // Activities collection
    match /activities/{activityId} {
      allow read: if isApproved();
      allow create, update, delete: if isTeacher() || isAdmin();
    }

    // Calendar events collection (used as 'calendar_events' in code)
    match /calendar_events/{eventId} {
      allow read: if isApproved();
      allow create, update, delete: if isAdmin();
    }

    // Reports collection (used as 'student_reports' in code)
    match /student_reports/{reportId} {
      allow read: if isApproved();
      allow create, update, delete: if isTeacher() || isAdmin();
    }

    // Gallery collection
    match /gallery/{galleryId} {
      allow read: if isApproved();
      allow create, update, delete: if isTeacher() || isAdmin();
    }

    // Assignments collection
    match /assignments/{assignmentId} {
      allow read: if isApproved();
      allow create, update: if isTeacher() || isAdmin();
      allow delete: if isTeacher() || isAdmin();
    }

    // Assignment submissions collection
    match /assignment_submissions/{submissionId} {
      allow read: if isApproved();
      allow create, update: if isApproved();
      allow delete: if isTeacher() || isAdmin();
    }

    // Messages/Conversations collection
    match /conversations/{conversationId} {
      allow read: if isApproved();
      allow create: if isApproved();
      // Allow any participant to update (for read receipts, last message)
      allow update: if isApproved();
      allow delete: if isAdmin();
    }

    // Individual messages within conversations
    match /conversations/{conversationId}/messages/{messageId} {
      allow read: if isApproved();
      allow create: if isApproved();
      // Allow updating for read receipts
      allow update: if isApproved();
      allow delete: if isAdmin();
    }

    // Lesson plans collection
    match /lesson_plans/{planId} {
      allow read: if isApproved();
      allow create, update: if isTeacher() || isAdmin();
      allow delete: if isTeacher() || isAdmin();
    }

    // FCM tokens collection
    match /fcm_tokens/{tokenId} {
      allow read, write: if request.auth != null;
    }

    // Notifications collection
    match /notifications/{notifId} {
      allow read: if isApproved();
      allow create: if isApproved();
      allow update: if isApproved();
      allow delete: if isAdmin();
    }

    // Class updates (daily/weekly)
    match /class_updates/{updateId} {
      allow read: if isApproved();
      allow create, update, delete: if isTeacher() || isAdmin();
    }

    // Incident reports collection
    match /incidents/{incidentId} {
      allow read: if isApproved();
      allow create: if isTeacher() || isAdmin();
      allow update: if isApproved();
      allow delete: if isAdmin();
    }

    // Feed posts collection (activity feed)
    match /feed_posts/{postId} {
      allow read: if isApproved();
      allow create, update, delete: if isTeacher() || isAdmin();
    }

    // QR tokens collection (check-in codes)
    match /qr_tokens/{tokenId} {
      allow read: if isApproved();
      allow create, update, delete: if isTeacher() || isAdmin();
    }

    // Check-in records collection
    match /check_in_records/{recordId} {
      allow read: if isApproved();
      allow create: if isApproved();
      allow update, delete: if isTeacher() || isAdmin();
    }
  }
}
